# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (server-only)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Google AI Studio key (free) - powers Gemma 4 vision OCR for lab reports.
GEMINI_API_KEY=
# Optional override; defaults to gemma-4-26b-a4b-it (hosted Gemini API).
# Set to gemma-4-12b-it once it is available on the hosted API.
GEMMA_OCR_MODEL=
