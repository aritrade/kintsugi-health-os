# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (server-only)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Lab-report OCR (privacy-first provider priority) ---
# 1) Self-hosted Ollama running true Gemma 4 12B (preferred: images stay on your infra).
#    Point at your Oracle box, e.g. https://<IP>.sslip.io/ollama  (behind Caddy + bearer token).
OLLAMA_BASE_URL=
OLLAMA_OCR_TOKEN=
# Defaults to gemma4:12b
OLLAMA_OCR_MODEL=
# 2) Fallback: hosted Gemini API with a free Gemma 4 vision model.
#    Used only if OLLAMA_BASE_URL is unset or the box is unreachable.
GEMINI_API_KEY=
# Optional override; defaults to gemma-4-26b-a4b-it (hosted Gemini API).
GEMMA_OCR_MODEL=
